// Zed keymap

[
  {
    "context": "VimControl && !menu",
    "bindings": {
      // vim essentials
      "space k": "pane::ActivateNextItem",
      "alt-k": "pane::CloseActiveItem",
      "space j": "pane::ActivatePreviousItem",
      "alt-e": "workspace::ToggleLeftDock",
      // vim pane size
      "alt-shift-h": "vim::ResizePaneLeft",
      "alt-shift-k": "vim::ResizePaneUp",
      "alt-shift-l": "vim::ResizePaneRight",
      "alt-shift-n": "vim::ResetPaneSizes",
      "alt-shift-m": "vim::MaximizePane",
      "alt-shift-j": "vim::ResizePaneDown",
      // good to have
      "alt-c": "workspace::NewCenterTerminal",
      "space c": "workspace::ToggleCenteredLayout",
      // vim pane movement
      "alt-n h": "workspace::ActivatePaneLeft",
      "alt-n k": "workspace::ActivatePaneUp",
      "alt-n l": "workspace::ActivatePaneRight",
      "alt-n j": "workspace::ActivatePaneDown",
      // move split pane and tab swap
      "alt-n H": "pane::SplitAndMoveLeft",
      "alt-n K": "pane::SwapItemLeft",
      "alt-n L": "pane::SwapItemRight",
      "alt-n J": "pane::SplitAndMoveDown",
    },
  },
  {
    "context": "!menu && vim_mode != normal",
    "bindings": {
      // vim must have
      "alt-j": "vim::NormalBefore"
    }
  }
]
