// Zed settings

{
  "semantic_tokens": "combined",
  "agent": {
    "dock": "right",
    "default_profile": "ask",
    "default_model": {
      "enable_thinking": true,
      "provider": "openrouter",
      "model": "nvidia/nemotron-3-super-120b-a12b:free"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "buffer_font_size": 17,
  "show_edit_predictions": false,
  "icon_theme": "Zed (Default)",
  "agent_buffer_font_size": 14,
  "buffer_font_family": "FiraMono Nerd Font",
  "ui_font_size": 17,
  "buffer_font_weight": 400,
  "relative_line_numbers": "enabled",
  "agent_ui_font_size": 17,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Mellow"
  },
  "scrollbar": {
    "show": "never"
  },
  "soft_wrap": "editor_width",
  "gutter": {
    "folds": false
  },
  "experimental.theme_overrides": {
    "toolbar.background": "#161617",
    "tab.active_background": "#161617",
    "panel.background": "#1b1b1d",
    "title_bar.background": "#161617",
    "border": "#131314",
    "border.variant": "#161617",
    "terminal.background": "#161617",
    "tab.inactive_background": "#1b1b1d",
    "status_bar.background": "#161617",
    "tab_bar.background": "#1b1b1d",
    "syntax": {
      "comment": {
        "font_style": "normal"
      }
    }
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "vim_mode": true,
  "hide_mouse": "on_typing_and_action",
  "terminal": {
    "font_family": "JetBrainsMonoNL Nerd Font",
    "font_weight": 400,
    "line_height": {
      "custom": 1.4
    },
    "default_height": 420
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 1000
  },
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false
  },
  "inline_code_actions": false,
  "code_lens": "on",
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15
  },
  "cli_default_open_behavior": "existing_window"
}
